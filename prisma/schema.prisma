// PostgreSQL schema: 用于 Vercel 生产部署
// 切换步骤：
//   1. 在 Vercel 控制台 Storage → Add Database → Postgres
//   2. Environment Variables 中会自动注入 DATABASE_URL
//   3. 终端执行：npx prisma migrate deploy --schema=./prisma/schema.prisma
//   4. 重新部署

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id        String     @id @default(uuid())
  name      String
  age       Int?
  school    String?
  gender    String?
  createdAt DateTime   @default(now())
  responses Response[]
}

// 90 道题独立列（q1..q90），分数为 1-10 或 1-5 的整数
// q1..q60 = 学习力，q61..q90 = 学业压力
model Response {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  // 学习力 10 个维度的综合得分（便于前端直接渲染百分比）
  dimensionScores  String? // JSON: { "思维模式": 85, ... }
  pressureScores   String? // JSON: { "学业负担": 3.2, ... }
  mindsetLabel     String?
  q1        Int?
  q2        Int?
  q3        Int?
  q4        Int?
