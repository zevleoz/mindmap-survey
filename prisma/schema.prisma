// PostgreSQL schema: 用于 Vercel 生产部署
// 切换步骤：
//   1. 在 Vercel 控制台 Storage → Add Database → Postgres
//   2. Environment Variables 中会自动注入 DATABASE_URL
//   3. 终端执行：npx prisma migrate deploy --schema=./prisma/schema.prisma
//   4. 重新部署

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id        String     @id @default(uuid())
  name      String
  age       Int?
  school    String?
  gender    String?
  createdAt DateTime   @default(now())
  responses Response[]
}

model Response {
  id              String   @id @default(uuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id])
  learningAnswers String
  stressAnswers   String
  learningScores  String
  stressScores    String
  createdAt       DateTime @default(now())
}
