// Prisma schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Student {
  id         String     @id @default(uuid())
  name       String
  age        Int?
  school     String?
  gender     String?
  createdAt  DateTime   @default(now())
  responses  Response[]
}

model Response {
  id              String   @id @default(uuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id])
  learningAnswers String   // JSON：60 题学习力原始答案
  stressAnswers   String   // JSON：30 题学业压力原始答案
  learningScores  String   // JSON：10 个学习力维度得分
  stressScores    String   // JSON：5 个学业压力维度得分
  createdAt       DateTime @default(now())
}
