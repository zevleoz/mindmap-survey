// SQLite schema: 开箱即用，无需外部数据库
// 如需切换回 PostgreSQL，把 datasource.db 改为 provider = "postgresql" 并设置 DATABASE_URL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Student {
  id        String     @id @default(uuid())
  name      String
  age       Int?
  school    String?
  gender    String?
  createdAt DateTime   @default(now())
  responses Response[]
}

model Response {
  id              String   @id @default(uuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id])
  learningAnswers String
  stressAnswers   String
  learningScores  String
  stressScores    String
  createdAt       DateTime @default(now())
}
